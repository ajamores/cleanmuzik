# CleanMuzik — environment template.
# Copy this file to `.env` (which is git-ignored) and fill in the real values.
# NOTHING reads this yet — the FastAPI backend that consumes it is not built.
# This just captures the keys so they're on hand when the build starts.

# --- Jellyfin (auto-scan after a track lands) -------------------------------
# JELLYFIN_URL: where Jellyfin is reachable. Phase 0 = the laptop itself.
JELLYFIN_URL=http://localhost:8096
# JELLYFIN_API_KEY: Jellyfin Dashboard -> API Keys -> New. Paste it in `.env`, not here.
JELLYFIN_API_KEY=

# --- Last.fm (genre tags via beets `lastgenre`) -----------------------------
# Not obtained yet. Until set, tracks land without genre (not a failure).
LASTFM_APIKEY=

# --- AcoustID (fingerprint lookup via beets `chroma`) -----------------------
# OPTIONAL — beets' built-in key works (proven in the spike). Set only for
# higher rate limits.
ACOUSTID_APIKEY=
